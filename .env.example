# ════════════════════════════════════════════════════════════════
#  .env.example  —  Copy to .env and fill in real values
#  NEVER commit .env to Git
# ════════════════════════════════════════════════════════════════

# ── API Security ──────────────────────────────────────────────────
# Secret key that Salesforce sends in X-API-Key header
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GATEWAY_API_KEY=change-this-to-a-strong-random-secret

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# gpt-4o-mini = cheapest,  gpt-4o = best quality
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=600

# ── Pinecone ──────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_ME4EB_BC1ar472jcEpEqQAJcFRCXpHUf5noc5bMXBY6utVryC9xoLDMJVBNVf3DCTnuhV
PINECONE_INDEX_NAME=salesforce-kb
# Dimension must match your embedding model:
#   text-embedding-3-small = 1536
#   text-embedding-ada-002  = 1536
#   text-embedding-3-large  = 3072
PINECONE_DIMENSION=1536
PINECONE_METRIC=cosine
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Namespaces — one per knowledge domain
PINECONE_NS_BILLING=billing
PINECONE_NS_TECHNICAL=technical
PINECONE_NS_GENERAL=general
# How many top chunks to retrieve
PINECONE_TOP_K=5

# ── Redis ─────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Redis Cloud / Upstash: rediss://username:password@host:port
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600
# Semantic cache similarity threshold (0.0 = exact, 1.0 = anything)
REDIS_SEMANTIC_SCORE_THRESHOLD=0.95
# Simple in-memory cache fallback if Redis is unavailable
CACHE_FALLBACK_ENABLED=true

# ── LangGraph ─────────────────────────────────────────────────────
LANGGRAPH_MAX_RETRIES=3
LANGGRAPH_TIMEOUT_SECONDS=30

# ── Guardrails ────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
# Toxicity score threshold (0.0–1.0); block if score exceeds this
TOXICITY_THRESHOLD=0.7
# PII entity types to redact (comma-separated)
PII_ENTITIES=PERSON,EMAIL_ADDRESS,PHONE_NUMBER,CREDIT_CARD,IN_AADHAAR,IN_PAN

# ── App ───────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
APP_PORT=8000
